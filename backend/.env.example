# pslog backend 환경변수 템플릿 — `make setup` 이 자동 생성. 직접 작성도 가능.

# Database — Makefile 기본값: 5433 (app-chak 5432 와 충돌 회피)
DATABASE_URL=postgresql+asyncpg://pslog:pslog123@localhost:5433/pslog

# JWT — `python3 -c "import secrets; print(secrets.token_urlsafe(32))"` 로 생성
SECRET_KEY=

# Phase 2 — Fernet 마스터 키 (webhook secret / GitHub PAT 암호화)
# `python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"` 로 생성
pslog_FERNET_KEY=

# Phase 5a — webhook callback URL (GitHub 가 호출할 외부 URL)
# 로컬: http://localhost:8081 / 운영: Cloudflare Tunnel URL
pslog_PUBLIC_URL=http://localhost:8081

# CORS — frontend dev server (Vite default 5173)
ALLOWED_ORIGINS=http://localhost:5173
